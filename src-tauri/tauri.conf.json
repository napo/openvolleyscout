{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "openvolleyscout",
  "version": "0.4.0",
  "identifier": "io.github.napo.openvolleyscout",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "OpenVolleyScout",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/**", "$VIDEO/**", "$DOWNLOAD/**", "$DOCUMENT/**"]
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQ5RjVGMDQwM0U2RDFDQTEKUldTaEhHMCtRUEQxU1FJdStzeENrZzdJeDAwdHdSOTZ3TW1DSDkvMzdKcnh5aW1vazVKc3pqU0wK",
      "endpoints": [
        "https://github.com/napo/openvolleyscout/releases/latest/download/latest.json"
      ]
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "dmg", "nsis", "msi"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "android": {
      "debugApplicationIdSuffix": ".debug"
    }
  }
}
